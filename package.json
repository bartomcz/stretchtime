{
  "name": "stretchtime",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local-only webcam presence monitor",
  "main": "dist/backend/server.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc",
    "start": "npm run build && node dist/backend/server.js",
    "dev": "npm run clean && tsc-watch --onSuccess \"node dist/backend/server.js\"",
    "test": "npm run build && node --test dist/test/*.test.js",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@tensorflow-models/coco-ssd": "2.2.3",
    "@tensorflow/tfjs": "4.22.0",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "22.20.1",
    "tsc-watch": "7.2.1",
    "typescript": "5.9.3"
  }
}
